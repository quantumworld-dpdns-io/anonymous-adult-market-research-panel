# Environment — development | staging | production
ENVIRONMENT=development

# IBM Quantum (required only when backend=ibm_quantum)
IBM_QUANTUM_API_KEY=

# Backend configuration
DEFAULT_BACKEND=aer
ENABLE_CUDAQ_BACKEND=false

# Limits
MAX_POPULATION_SIZE=1000000
MAX_SHOTS=8192

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=quantum-sampling-service

# Security
ALLOW_SEED_IN_PRODUCTION=false
