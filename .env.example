# ============================================================
# Anonymous Adult Market Research Panel — Environment Variables
# Copy to .env.local and fill in real values before running.
# NEVER commit .env.local to version control.
# ============================================================

# ─────────────────────────────
# Supabase
# ─────────────────────────────
SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder-anon-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder-service-key
SUPABASE_DB_PASSWORD=supersecret
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:3000
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# ─────────────────────────────
# Redis / DragonflyDB
# ─────────────────────────────
REDIS_URL=redis://:devredispassword@localhost:6379/0
REDIS_PASSWORD=devredispassword

# ─────────────────────────────
# ZK Proving Service
# ─────────────────────────────
ZK_TOKEN_SECRET=replace-with-32-plus-char-random-secret-for-zk-tokens
# ML-DSA signing key: base64 of 4864-byte ML-DSA-65 secret key
# Generate: python3 -c "from pyoqs import Sig; s=Sig('ML-DSA-65'); pk,sk=s.generate_keypair(); import base64; print(base64.b64encode(bytes(sk)).decode())"
ML_DSA_SIGNING_KEY_B64=
ML_DSA_PUBLIC_KEY_B64=
# RISC0: set to 1 in dev/test, always 0 in production
RISC0_DEV_MODE=1

# ─────────────────────────────
# Go API Gateway
# ─────────────────────────────
LISTEN_ADDR=:8081
ZK_PROVING_ADDR=zk-proving:50051
ANALYTICS_ADDR=http://localhost:8001
QUANTUM_ADDR=http://localhost:8002
SERVICE_HMAC_SECRET=replace-with-32-plus-char-random-secret-for-service-hmac
ALLOWED_ORIGINS=http://localhost:3000
INTERNAL_API_URL=http://localhost:8081/internal

# ─────────────────────────────
# Analytics Service (Flower / DP)
# ─────────────────────────────
ANALYTICS_PORT=8001
DUCKDB_PATH=/data/analytics.duckdb
# Default DP parameters (overridable per study)
DEFAULT_EPSILON_BUDGET=10.0
DEFAULT_DELTA=0.00001
DEFAULT_EPSILON_PER_ROUND=1.0
MIN_COHORT_SIZE=50

# ─────────────────────────────
# Quantum Service
# ─────────────────────────────
QUANTUM_PORT=8002
# IBM Quantum: leave blank to use local Aer simulator
IBM_QUANTUM_API_KEY=
# Set to "true" only on nodes with NVIDIA GPU and cudaq installed
ENABLE_CUDAQ_BACKEND=false
# "development" disables seed restriction; "production" ignores seed param
NODE_ENV=development

# ─────────────────────────────
# Next.js Frontend
# ─────────────────────────────
API_GATEWAY_URL=http://localhost:8081
NEXT_PUBLIC_ZK_THREADS=4
NEXT_PUBLIC_MIN_COHORT_FOR_RESULTS=50

# ─────────────────────────────
# Observability / Telemetry
# ─────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=panel-local
# Arize Phoenix (optional, for LLM/AI observability)
PHOENIX_API_KEY=
# Weights & Biases (optional, for FL experiment tracking)
WANDB_API_KEY=

# ─────────────────────────────
# AI / LLM (optional features)
# ─────────────────────────────
ANTHROPIC_API_KEY=
# Model ID for study question generation / report drafting
CLAUDE_MODEL=claude-sonnet-4-6

# ─────────────────────────────
# TLS (Production only — leave blank in local dev)
# ─────────────────────────────
TLS_CERT_FILE=
TLS_KEY_FILE=

# ─────────────────────────────
# Qdrant
# ─────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
