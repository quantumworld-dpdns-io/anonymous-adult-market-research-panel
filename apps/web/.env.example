# Supabase (public — safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role (server-side ONLY — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Internal service URLs (server-side only)
API_GATEWAY_URL=http://api-gateway:8080
INTERNAL_API_URL=http://api-gateway:8080/internal

# Service HMAC secret for internal auth
SERVICE_HMAC_SECRET=change-me-in-production

# Feature flags
NEXT_PUBLIC_ZK_THREADS=4
NEXT_PUBLIC_MIN_COHORT_FOR_RESULTS=50

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=anonymous-panel-web
